{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/webhook.py": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/report/:slug", "destination": "/report.html" }
  ]
}
